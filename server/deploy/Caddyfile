# Vault internal router. TLS terminates at tailscale serve; Caddy speaks
# plain HTTP on localhost. One port per audience, every app at its own root
# (never subpaths — see DESIGN.md "Routing").
{
	auto_https off
}

# ---- member API surface (tailscale serve 443) -------------------------
:8080 {
	# Job progress is Server-Sent Events: this route must not buffer, or the
	# client sees stale/frozen progress. flush_interval -1 = stream through.
	@sse path /v1/jobs/watch
	reverse_proxy @sse vaultd:8080 {
		flush_interval -1
	}
	reverse_proxy vaultd:8080
}

# ---- Pocket ID at root (tailscale serve 9443) -------------------------
:8081 {
	reverse_proxy pocket-id:1411
}

# ---- admin surface (tailscale serve 8443, admin-only by Tailscale ACL) -
:8082 {
	reverse_proxy qbittorrent:8090
}

# ---- Vault admin panel (tailscale serve 8444, admin-only by ACL) ------
:8083 {
	reverse_proxy vaultd:8081
}
