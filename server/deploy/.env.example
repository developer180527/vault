# Copy to .env (never commit .env) and fill in.

# Your server's MagicDNS name (tailscale status shows it).
TS_HOSTNAME=vault-server.taild29644.ts.net

# The `vault` system user created by bootstrap.sh.
VAULT_UID=990
VAULT_GID=990

TZ=Asia/Kolkata

# Generate once:  openssl rand -base64 32
POCKET_ID_ENCRYPTION_KEY=CHANGE_ME

# vaultd's OIDC client id — created when you register vaultd as an OAuth2/OIDC
# client inside Pocket ID's admin UI (:9443 → Administration → OIDC Clients).
# Fill this in AFTER that step; vaultd's auth endpoints stay disabled until then.
VAULTD_OIDC_CLIENT_ID=CHANGE_ME
